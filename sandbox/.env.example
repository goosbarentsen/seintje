# Enable Banking sandbox application — see https://enablebanking.com/cp/applications
EB_APPLICATION_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the PEM private key Enable Banking generated for this application.
# Keep this file OUTSIDE the repo. Do not place it inside /sandbox or anywhere
# under this git repository - config.js will refuse to run if it detects that.
EB_PRIVATE_KEY_PATH=/absolute/path/outside/this/repo/enablebanking-sandbox.pem

# Must exactly match a redirect URL registered for this application in the
# Enable Banking Control Panel.
EB_REDIRECT_URL=http://localhost:3344/callback
